{
  "name": "@hi-dorri/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "platform-wallets:init": "ts-node -r tsconfig-paths/register src/scripts/init-platform-wallets.ts",
    "platform-wallets:trustlines": "ts-node -r tsconfig-paths/register src/scripts/create-platform-trustlines.ts",
    "dorri-issuer:configure": "ts-node -r tsconfig-paths/register src/scripts/configure-dorri-issuer.ts",
    "reset:dev-data": "ts-node -r tsconfig-paths/register src/scripts/reset-dev-data.ts",
    "seed:dev": "ts-node -r tsconfig-paths/register src/scripts/seed-dev.ts",
    "dorri:return": "ts-node -r tsconfig-paths/register src/scripts/return-dorri-to-issuer.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.7",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.7",
    "@nestjs/platform-express": "^10.4.7",
    "@prisma/client": "^5.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "xrpl": "^4.6.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.7",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
